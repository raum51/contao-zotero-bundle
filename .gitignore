
# =============================
# raum51/contao-zotero-bundle .gitignore
# Target OS/IDE: macOS + VS Code
# =============================

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# --- VS Code ---
.vscode/
.history/

# --- Composer / PHP (Library best practice) ---
/vendor/
/composer.phar
# Libraries should not commit composer.lock
/composer.lock
/.phpunit.result.cache
/.php-cs-fixer.cache
/.php-cs-fixer.php
/.php-cs-fixer.dist.php

# --- Symfony/Contao (if bundle is run standalone for tests) ---
/var/
/var/*
!/var/.gitkeep
/public/

# --- Node (optional) ---
/node_modules/
/package-lock.json
/pnpm-lock.yaml
/yarn.lock
/.pnp*/
/.cache/

# --- Logs / Temp ---
/logs/
*.log
/tmp/

# --- IDEs ---
/.idea/
*.iml

# --- Coverage ---
/coverage/

# --- Misc ---
Thumbs.db
